---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { getPeerReviewedPapers } from "../utils/getPublications.ts";
import { getEducation, getExperience } from "../utils/getCV.ts";

const papers = getPeerReviewedPapers();
const education = getEducation();
const experience = getExperience();

const dois = papers.map((p) => {
  const match = p.href.match(/(?:doi\.org|dx\.doi\.org)\/(.+)$/);
  return match ? match[1] : null;
});
const validDois = dois.filter(Boolean) as string[];

const citationCounts: Record<string, number> = {};

if (validDois.length > 0) {
  try {
    const res = await fetch(
      "https://api.semanticscholar.org/graph/v1/paper/batch?fields=citationCount",
      {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ ids: validDois.map((doi) => `DOI:${doi}`) }),
      }
    );
    if (res.ok) {
      const data = await res.json();
      data.forEach((item: { citationCount?: number } | null, i: number) => {
        if (item?.citationCount != null) {
          citationCounts[validDois[i]] = item.citationCount;
        }
      });
    }
  } catch {
    // citation counts are non-critical; silently skip on failure
  }
}

const papersWithCitations = papers.map((paper, i) => ({
  ...paper,
  citationCount: dois[i] != null ? citationCounts[dois[i]!] : undefined,
}));
---

<Layout title="Work — Tony Barrows" description="Research, publications, and academic background of Tony Barrows">
  <Navigation />
  <main>
    <h1>Work</h1>

    <p style="text-align: center">
      <a href="/assets/ajb_cv.pdf" target="_blank" rel="noopener">Open CV</a> &middot;
      <a href="/assets/ajb_cv.pdf" download>Download CV</a>
    </p>

    <h2>Education</h2>
    <ul class="experience-list">
      {education.map((item) => (
        <li>
          <p class="exp-period">{item.period}</p>
          <p class="exp-position">
            {item.institution_url
              ? <><strong>{item.degree}</strong>, <a href={item.institution_url} target="_blank" rel="noopener">{item.institution}</a>{item.location ? `, ${item.location}` : ""}</>
              : <><strong>{item.degree}</strong>, {item.institution}{item.location ? `, ${item.location}` : ""}</>
            }
          </p>
          {item.thesis && <p class="exp-desc"><em>Thesis: {item.thesis}</em></p>}
        </li>
      ))}
    </ul>

    <h2>Experience</h2>
    <ul class="experience-list">
      {experience.map((item) => (
        <li>
          <p class="exp-period">{item.period}</p>
          <p class="exp-position">
            {item.organization_url
              ? <><strong>{item.position}</strong>, <a href={item.organization_url} target="_blank" rel="noopener">{item.organization}</a></>
              : <><strong>{item.position}</strong>, {item.organization}</>
            }
          </p>
          {item.description && <p class="exp-desc">{item.description}</p>}
        </li>
      ))}
    </ul>

    <h2>Papers</h2>

    <p>
      <span>Sort by: </span>
      <button class="sort-btn active" data-sort="date">
        <span class="active-label">Date</span>
      </button>
      <button class="sort-btn" data-sort="citations">Citations</button>
    </p>

    <ol id="papers-list">
      {papersWithCitations.map((paper) => {
        const year = paper.citation.match(/\b(20\d{2})\b/)?.[1] ?? "0";
        return (
          <li data-year={year} data-citations={paper.citationCount ?? -1} style="display: flex; gap: 1rem; align-items: flex-start;">
            <div style="width: 100px; flex-shrink: 0;">
              {paper.image && (
                <a href={paper.href} target="_blank" rel="noopener">
                  <img src={paper.image} alt="" style="width: 100px; margin-top: 0.2em;" />
                </a>
              )}
            </div>
            <div>
              <a href={paper.href} target="_blank" rel="noopener">
                <strong>{paper.title}</strong>
              </a><br />
              <span>{paper.authors}</span><br />
              <em>{paper.citation}</em>
              {paper.citationCount != null && (
                <span> &middot; {paper.citationCount} {paper.citationCount === 1 ? "citation" : "citations"}</span>
              )}
            </div>
          </li>
        );
      })}
    </ol>
  </main>
  <Footer />
</Layout>

<script>
  const list = document.getElementById("papers-list")!;
  const buttons = document.querySelectorAll<HTMLButtonElement>(".sort-btn");

  function setActive(active: HTMLButtonElement) {
    buttons.forEach((btn) => {
      const isActive = btn === active;
      btn.classList.toggle("active", isActive);
      const label = btn.querySelector(".active-label");
      if (isActive && !label) {
        btn.innerHTML = `<span class="active-label">${btn.textContent}</span>`;
      } else if (!isActive && label) {
        btn.textContent = label.textContent;
      }
    });
  }

  function sortList(key: "date" | "citations") {
    const items = Array.from(list.querySelectorAll<HTMLLIElement>("li"));
    items.sort((a, b) => {
      const av = Number(a.dataset[key === "date" ? "year" : "citations"]);
      const bv = Number(b.dataset[key === "date" ? "year" : "citations"]);
      return bv - av;
    });
    items.forEach((item) => list.appendChild(item));
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      sortList(btn.dataset.sort as "date" | "citations");
      setActive(btn);
    });
  });
</script>
