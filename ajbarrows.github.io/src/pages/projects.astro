---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { projectsContent } from "../config/content.ts";
---

<Layout title={projectsContent.meta.title} description={projectsContent.meta.description}>
  <Navigation />
  <main>
    <h1>{projectsContent.title}</h1>
    <p>{projectsContent.description}</p>
    {projectsContent.projects.length === 0 && <p>No projects listed yet.</p>}
    <ol>
      {projectsContent.projects.map((project) => (
        <li>
          <a href={project.href} target="_blank" rel="noopener">
            <strong>{project.title}</strong>
          </a>
          <br />
          <span>{project.description}</span>
        </li>
      ))}
    </ol>
  </main>
  <Footer />
</Layout>
