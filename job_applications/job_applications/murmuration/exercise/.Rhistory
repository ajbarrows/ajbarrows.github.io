) %>%
group_by(subject_id) %>%
tidyr::fill(TRTGRP)
df <- df %>% filter(subject_id %in% sid_df$subject_id)
df %>%
group_by(trial, TRTGRP) %>%
distinct(subject_id) %>%
count() %>%
tidyr::pivot_wider(
names_from = trial,
values_from = n
)
df_sub <- df %>%
ungroup() %>%
select(
subject_id, trial, TRTGRP, VISIT,
AGE, SEXN,
FTNSCORE,
STOPSMKN, INTMOT, QTNX6MO, WANTSMK, WANTSMKN, NTSMK1YR,
CGSPERDY, INTRED, REDNXM, RED50, RED501YR, CHSMK,
SMKAGE,SMKNON, SMKQT, SMKQTLA,
ANXA, ANXA1N, DEPR2X, DEPR2XN,
EMOWELL, SCQHAPY,
NUCORES, SMKQTY, SMKSTP,
PEPUP, pepup_swi,
CALMEFFT, CLMEFTA, LSTCGEX, UNPLSYM,
FREQURGE, STRTHURG, SATISMOK
)
# sanity check
setdiff(colnames(df), colnames(df_sub))
# rename
df_sub <- df_sub %>%
mutate(
WANTSMKN = recode(
WANTSMKN,
"0" = "NOT AT ALL",
"1" = "A LITTLE",
"2" = "SOMEWHAT",
"4" = "A LOT",
.missing = NA_character_
),
ANXA1N = recode(
ANXA1N,
"0" = "NOT AT ALL",
"1" = "SOMEWHAT",
"2" = "MODERATELY SO",
"3" = "VERY MUCH SO",
"4" = "EXTREMELY SO",
.missing = NA_character_
),
DEPR2XN = recode(
DEPR2XN,
"0" = "NOT AT ALL",
"1" = "SOMEWHAT",
"2" = "MODERATELY SO",
"3" = "VERY MUCH SO",
"4" = "EXTREMELY SO",
.missing = NA_character_
)) %>%
tidyr::unite(WANTSMKN, WANTSMK, na.rm = TRUE) %>%
tidyr::unite(ANXA1N, ANXA, na.rm = TRUE) %>%
tidyr::unite(DEPR2XN, DEPR2X, na.rm = TRUE) %>%
select(-c(WANTSMKN, ANXA1N, DEPR2XN))
# divide continuous variables into 5 categories
df_sub <- df_sub %>%
mutate(PEPUP = cut(
PEPUP,
breaks = c(0, 2, 4, 6, 8, 10),
labels = c(
"NOT AT ALL",
"MILD",
"MODERATE",
"STRONG",
"VERY STRONG"
)
)) %>%
mutate(CALMEFFT = cut(
CALMEFFT,
breaks = c(0, 2, 4, 6, 8, 10),
labels = c(
"NOT AT ALL",
"MILD",
"MODERATE",
"STRONG",
"VERY STRONG"
)
))
df_sub <- df_sub %>%
tidyr::unite(col = "PEPUP", PEPUP, pepup_swi, na.rm = TRUE) %>%
tidyr::unite(col = "CALMEFFT", CALMEFFT, CLMEFTA, na.rm = TRUE)
# collapse treatment groups --> active vs. placebo
df_sub <- df_sub %>%
mutate(
trt_recode = tolower(TRTGRP),
trt_recode = ifelse(stringr::str_detect(trt_recode,"placebo"), "placebo", trt_recode),
trt_recode = ifelse(stringr::str_detect(trt_recode, "active"), "active", trt_recode),
trt_recode = as.factor(trt_recode)
)
# collapse follow-up points Week 10 and Week 13
df_sub$VISIT[df_sub$VISIT == "WEEK 13"] <- "WEEK 10"
# rename follow-up points
df_sub$VISIT[df_sub$VISIT == "VISIT 1"] <- "WEEK 1"
cols <- c("FALSE" = "#00BFC4", "TRUE" = "#F8766D")
df_sub %>%
group_by(VISIT) %>%
summarize(across(everything(), function(x)all(is.na(x)))) %>%
tidyr::pivot_longer(-VISIT) %>%
ggplot(aes(x = name, y = VISIT, fill = value)) +
geom_raster() +
scale_fill_manual(
values = cols
) +
coord_flip() +
theme(axis.text.x = element_text(hjust = 1, angle = 45)) +
labs(
fill = "No Value Present\n(Blue is Good)",
x = "Time Point",
y = "Variable",
title = "Missing Data by Time Point"
)
df_sub <- df_sub %>%
group_by(subject_id) %>%
tidyr::fill(
SEXN, AGE, NTSMK1YR,
QTNX6MO, RED50, RED501YR,
REDNXM, SMKAGE, SMKNON,
SMKQT, SMKQTLA,
)
df_sub %>%
filter(!is.na(VISIT)) %>%
group_by(VISIT) %>%
summarize(across(everything(), function(x)all(is.na(x)))) %>%
tidyr::pivot_longer(-VISIT) %>%
ggplot(aes(x = name, y = VISIT, fill = value)) +
geom_raster() +
scale_fill_manual(
values = cols
) +
coord_flip() +
theme(axis.text.x = element_text(hjust = 1, angle = 45)) +
labs(
fill = "No Value Present\n(Blue is Good)",
x = "Time Point",
y = "Variable",
title = "Missing Data by Time Point",
subtitle = "Baseline Data Extrapolated"
)
df_sub %>%
group_by(VISIT) %>%
summarize(across(everything(), ~sum(!is.na(.x)) / n())) %>%
tidyr::pivot_longer(-VISIT) %>%
ggplot(aes(x = name, y = VISIT, fill = as.numeric(value))) +
geom_raster() +
coord_flip() +
theme(
axis.text.x = element_text(hjust = 1, angle = 45),
text = element_text(size = 15)) +
labs(
title = "Percent Missing Data by Session",
subtitle = "Lighter is Better",
fill = "Value\nPresent"
)
df_sub %>%
group_by(trial) %>%
summarize(across(everything(), ~sum(!is.na(.x)) / n())) %>%
tidyr::pivot_longer(-trial) %>%
ggplot(aes(x = name, y = trial, fill = as.numeric(value))) +
geom_raster() +
coord_flip() +
theme(axis.text.x = element_text(hjust = 1, angle = 45)) +
labs(
title = "Percent Missing Data by Trial",
subtitle = "Lighter is Better",
fill = "Value\nPresent"
)
