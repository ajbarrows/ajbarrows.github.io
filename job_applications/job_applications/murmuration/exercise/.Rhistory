mis_threshold <- 0.3
# gives matrix of trial-Visit combinations with > 30% missing data
df_sub <- df_sub %>%
group_by(trial, VISIT) %>%
mutate(
across(
where(is.numeric),
~ ifelse(sum(is.na(.x) / n()) > mis_threshold, NA, .x)
)
)
