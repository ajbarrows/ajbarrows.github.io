---
import Navigation from "../components/Navigation.astro";
import Footer from "../components/Footer.astro";
import { musicContent } from "../config/content";
import { events } from "../config/events";
import { Image } from "astro:assets";

const galleryImages = Object.values(
  import.meta.glob<{ default: ImageMetadata }>("../assets/images/music/**/*.{jpg,jpeg,png,webp}", { eager: true })
).map((mod) => mod.default);

const today = new Date();
today.setHours(0, 0, 0, 0);

const upcoming = events
  .filter((e) => new Date(e.date + "T00:00:00") >= today)
  .sort((a, b) => a.date.localeCompare(b.date));

const past = events
  .filter((e) => new Date(e.date + "T00:00:00") < today)
  .sort((a, b) => b.date.localeCompare(a.date));

function formatDate(iso: string) {
  return new Date(iso + "T00:00:00").toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{musicContent.meta.title}</title>
    <meta name="description" content={musicContent.meta.description} />
    <script is:inline>
      (function () {
        const savedTheme = localStorage.getItem("theme") || "light";
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const initialTheme = savedTheme === "system" ? (prefersDark ? "dark" : "light") : savedTheme;
        if (initialTheme === "dark") {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
      })();
    </script>
    <style>
      .dot-hexagon-light {
        background-image: radial-gradient(circle, #80808045 1px, transparent 1px),
          radial-gradient(circle, #80808045 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position: 0 0, 12px 20.78px;
      }
      .dot-hexagon-dark {
        background-image: radial-gradient(circle, #ffffff35 1px, transparent 1px),
          radial-gradient(circle, #ffffff35 1px, transparent 1px);
        background-size: 24px 41.57px;
        background-position: 0 0, 12px 20.78px;
      }
    </style>
  </head>
  <body class="bg-white dark:bg-neutral-900 transition-colors duration-300 min-h-screen flex flex-col">
    <div class="fixed inset-0 z-0 pointer-events-none">
      <div class="absolute inset-0 -z-10 dot-hexagon-light dark:dot-hexagon-dark"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(255,255,255,0.5)_60%,rgba(255,255,255,0.9)_85%,white_100%)] dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_50%,transparent_0%,rgba(23,23,23,0.5)_60%,rgba(23,23,23,0.9)_85%,rgb(23,23,23)_100%)] -z-10"></div>
      <div class="absolute left-0 right-0 top-0 -z-10 m-auto h-[1200px] w-[1200px] rounded-full bg-neutral-400 opacity-10 blur-[100px]"></div>
    </div>

    <main class="flex-1 relative z-10">
      <Navigation />
      <section class="relative z-20 max-w-4xl mx-auto mt-32 mb-12 px-7 lg:px-0">
        <h2 class="text-2xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-3xl lg:text-4xl">
          {musicContent.title}
        </h2>
        <p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400 sm:leading-7 lg:leading-8 sm:text-base lg:text-lg">
          {musicContent.description}
        </p>
        <div class="mt-6">
          <a
            href={musicContent.email.href}
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-neutral-900 rounded-lg hover:bg-neutral-700 dark:bg-neutral-100 dark:text-neutral-900 dark:hover:bg-neutral-200 transition-colors"
          >
            {musicContent.email.text}
          </a>
        </div>

        <div class="mt-16">
          <h3 class="text-xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-2xl">
            Events
          </h3>

          {upcoming.length > 0 && (
            <div class="mt-6">
              <h4 class="text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-4">
                Upcoming
              </h4>
              <ul class="flex flex-col divide-y divide-neutral-200 dark:divide-neutral-700">
                {upcoming.map((event) => (
                  <li class="py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                    <div>
                      <p class="font-medium text-neutral-900 dark:text-neutral-100">
                        {event.href
                          ? <a href={event.href} target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-2">{event.title}</a>
                          : event.title}
                      </p>
                      <p class="text-sm text-neutral-500 dark:text-neutral-400">
                        {event.venue} &mdash; {event.location}
                      </p>
                    </div>
                    <time class="text-sm text-neutral-500 dark:text-neutral-400 sm:text-right shrink-0">
                      {formatDate(event.date)}
                    </time>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {past.length > 0 && (
            <div class="mt-8">
              <h4 class="text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400 mb-4">
                Past
              </h4>
              <ul class="flex flex-col divide-y divide-neutral-200 dark:divide-neutral-700">
                {past.map((event) => (
                  <li class="py-4 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                    <div>
                      <p class="font-medium text-neutral-900 dark:text-neutral-100">
                        {event.href
                          ? <a href={event.href} target="_blank" rel="noopener noreferrer" class="hover:underline underline-offset-2">{event.title}</a>
                          : event.title}
                      </p>
                      <p class="text-sm text-neutral-500 dark:text-neutral-400">
                        {event.venue} &mdash; {event.location}
                      </p>
                    </div>
                    <time class="text-sm text-neutral-500 dark:text-neutral-400 sm:text-right shrink-0">
                      {formatDate(event.date)}
                    </time>
                  </li>
                ))}
              </ul>
            </div>
          )}

          {events.length === 0 && (
            <p class="mt-4 text-sm text-neutral-500 dark:text-neutral-400">
              No events listed. Add entries to <code>src/config/events.ts</code>.
            </p>
          )}
        </div>

        {galleryImages.length > 0 && (
          <div class="mt-16">
            <h3 class="text-xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100 sm:text-2xl mb-6">
              Photos
            </h3>
            <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
              {galleryImages.map((img, i) => (
                <button
                  class="gallery-btn block w-full break-inside-avoid rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-shadow duration-200 focus:outline-none focus:ring-2 focus:ring-neutral-400"
                  data-index={i}
                  aria-label={`Open photo ${i + 1}`}
                >
                  <Image
                    src={img}
                    alt={`Music photo ${i + 1}`}
                    class="w-full object-cover"
                    widths={[400, 800]}
                    sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
                  />
                </button>
              ))}
            </div>
          </div>
        )}

        <!-- Lightbox -->
        <div
          id="lightbox"
          class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 backdrop-blur-sm p-4"
          role="dialog"
          aria-modal="true"
          aria-label="Photo lightbox"
        >
          <button
            id="lightbox-close"
            class="absolute top-4 right-4 text-white/80 hover:text-white text-3xl leading-none focus:outline-none"
            aria-label="Close lightbox"
          >&times;</button>
          <button
            id="lightbox-prev"
            class="absolute left-4 text-white/80 hover:text-white text-4xl leading-none focus:outline-none select-none"
            aria-label="Previous photo"
          >&#8249;</button>
          <button
            id="lightbox-next"
            class="absolute right-4 text-white/80 hover:text-white text-4xl leading-none focus:outline-none select-none"
            aria-label="Next photo"
          >&#8250;</button>
          <img
            id="lightbox-img"
            src=""
            alt=""
            class="max-h-[90vh] max-w-full rounded-lg shadow-2xl object-contain"
          />
        </div>

        <script define:vars={{ galleryImages: galleryImages.map(img => img.src) }}>
          const btns = document.querySelectorAll(".gallery-btn");
          const lightbox = document.getElementById("lightbox");
          const lbImg = document.getElementById("lightbox-img");
          const lbClose = document.getElementById("lightbox-close");
          const lbPrev = document.getElementById("lightbox-prev");
          const lbNext = document.getElementById("lightbox-next");
          let current = 0;

          function open(i) {
            current = i;
            lbImg.src = galleryImages[i];
            lbImg.alt = `Music photo ${i + 1}`;
            lightbox.classList.remove("hidden");
            lightbox.classList.add("flex");
            lbClose.focus();
          }

          function close() {
            lightbox.classList.add("hidden");
            lightbox.classList.remove("flex");
          }

          btns.forEach((btn) => {
            btn.addEventListener("click", () => open(Number(btn.dataset.index)));
          });

          lbClose.addEventListener("click", close);
          lbPrev.addEventListener("click", () => open((current - 1 + galleryImages.length) % galleryImages.length));
          lbNext.addEventListener("click", () => open((current + 1) % galleryImages.length));

          lightbox.addEventListener("click", (e) => { if (e.target === lightbox) close(); });

          document.addEventListener("keydown", (e) => {
            if (lightbox.classList.contains("hidden")) return;
            if (e.key === "Escape") close();
            if (e.key === "ArrowLeft") open((current - 1 + galleryImages.length) % galleryImages.length);
            if (e.key === "ArrowRight") open((current + 1) % galleryImages.length);
          });
        </script>
      </section>
    </main>

    <Footer />
  </body>
</html>
