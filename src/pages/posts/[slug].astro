---
import Layout from "../../layouts/Layout.astro";
import Navigation from "../../components/Navigation.astro";
import Footer from "../../components/Footer.astro";
import { getPostBySlug, getAllPostSlugs } from "../../utils/getPosts";

export async function getStaticPaths() {
  const slugs = getAllPostSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/posts/");
}

const post = getPostBySlug(slug);

if (!post) {
  return Astro.redirect("/posts/");
}

const { frontmatter, Content } = post;

if (!Content) {
  return Astro.redirect("/posts/");
}
---

<Layout
  title={frontmatter.title ? `${frontmatter.title} — Tony Barrows` : "Post — Tony Barrows"}
  description={frontmatter.description}
>
  <Navigation />
  <main>
    <article>
      <h1>{frontmatter.title}</h1>
      {frontmatter.date && (
        <p class="author">
          <time datetime={frontmatter.date}>
            {new Date(frontmatter.date).toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })}
          </time>
          {frontmatter.readTime && <span> &middot; {frontmatter.readTime}</span>}
        </p>
      )}
      {frontmatter.description && (
        <div class="abstract"><p>{frontmatter.description}</p></div>
      )}
      <Content />
    </article>
  </main>
  <Footer />
</Layout>
